rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        request.auth.uid in ["KadtSZ3NJwcJCA8wpR9gt1PvrjT2"]
      );
    }

    // True if the current user is the conductor of a given trip
    function isConductorOf(viajeId) {
      return get(/databases/$(database)/documents/viajes/$(viajeId)).data.conductor.uid == request.auth.uid;
    }

    /* =====================  VERIFICACIONES  ===================== */
    match /verificaciones/{uid} {
      // Any signed-in user can read (needed for profile cards / verification badges).
      // Photo URLs are protected separately by Storage rules.
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && request.auth.uid == uid
        && !("adminNotes" in request.resource.data.keys())
        && !("history" in request.resource.data.keys())
        && !("reviewedAt" in request.resource.data.keys())
        && !("reviewedBy" in request.resource.data.keys())
        && (
          !("status" in request.resource.data.diff(resource.data).changedKeys())
          || (request.resource.data.status == "pending")
        );
      allow update: if isAdmin();
    }

    /* =====================  USUARIOS  ===================== */
    match /usuarios/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == uid;
      allow update: if isAdmin();

      match /vehiculos/{vehiculoId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isSignedIn() && request.auth.uid == uid;
      }

      match /documentos/{docId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isSignedIn() && request.auth.uid == uid;
      }

      // Reservation references — written when passenger books
      match /reservas/{reservaId} {
        allow read, create, delete: if isSignedIn() && request.auth.uid == uid;
      }

      // Ratings — readable by everyone, writable by any signed-in user (anyone can rate)
      match /calificaciones/{calId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && request.auth.uid == uid;
      }

      // Any other subcollections (future-proof)
      match /{subcol}/{docId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == uid;
      }
    }

    /* =====================  VIAJES  ===================== */
    match /viajes/{viajeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.conductor.uid == request.auth.uid
        || request.resource.data.diff(resource.data).changedKeys().hasOnly(["occupiedSeats"])
      );
      allow delete: if isSignedIn() && resource.data.conductor.uid == request.auth.uid;

      /* ─── Reservas ─── */
      match /reservas/{reservaId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        // Passenger or conductor (via denormalized field OR get() fallback for legacy docs)
        allow update, delete: if isSignedIn() && (
          resource.data.viajanteUid == request.auth.uid ||
          resource.data.conductorUid == request.auth.uid ||
          isConductorOf(viajeId)
        );
      }
    }

    /* =====================  NOTIFICATIONS  ===================== */
    match /notifications/{notifId} {
      allow create: if isSignedIn();
      allow read, update: if isSignedIn() && resource.data.toUid == request.auth.uid;
    }

    /* Default deny */
    match /{document=**} { allow read, write: if false; }
  }
}
