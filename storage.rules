rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Verificación (selfie, DNI, licencia) — solo dueño
    match /verificaciones/{uid}/{rest=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Profile photo — public read, owner write
    match /usuarios/{uid}/perfil-foto {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Other user files — owner only
    match /usuarios/{uid}/{rest=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Todo lo demás: bloqueado
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
